# Local development
VITE_API_URL=http://localhost:5000

# Production — HTTPS site cannot call http:// APIs (browser blocks "mixed content").
# Option A: Same domain reverse proxy (recommended). Leave empty so requests go to
#   https://prachivip.in/api/...  (nginx proxies /api and /uploads to your Node server).
# VITE_API_URL=

# Option B: Separate API on HTTPS only (never use http:// from an https:// page).
# VITE_API_URL=https://api.prachivip.in
